{
  "_id": "lotmAbilityB9002",
  "name": "Radiant Footwork",
  "type": "spell",
  "img": "icons/svg/damage/radiant.svg",
  "system": {
    "description": {
      "value": "<p><strong>Baseline (0 Spirituality):</strong> Your dance posture sharpens body control for 1 minute. You gain +5 feet movement speed, advantage on checks to resist being shoved or grappled, and your steps shed dim light in a 5-foot radius. Once per turn when you hit with a weapon attack, add +1 radiant damage.</p><p><strong>Higher Spend (upcast):</strong></p><ul><li><strong>+2 Spirituality:</strong> Movement bonus becomes +10 feet and the radiant damage rider becomes +Potency.</li><li><strong>+4 Spirituality:</strong> Choose one ally within 30 feet when you activate; that ally gains half your movement bonus for the duration.</li><li><strong>+6 Spirituality:</strong> You emit bright light in 10 feet (dim 10 feet beyond). While lit, difficult terrain caused by darkness or fear effects does not reduce your movement.</li></ul><p><em>Counterplay:</em> The stance ends early if you are incapacitated.</p>",
      "chat": ""
    },

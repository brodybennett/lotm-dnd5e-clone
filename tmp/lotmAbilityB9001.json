{
  "_id": "lotmAbilityB9001",
  "name": "Sunrise Chorus",
  "type": "spell",
  "img": "icons/svg/bard.svg",
  "system": {
    "description": {
      "value": "<p><strong>Baseline (0 Spirituality):</strong> You sing a clear, uplifting refrain. Choose up to 2 allies who can hear you within 30 feet (you can include yourself). Each target immediately ends one mundane fear effect; against supernatural fear, each target immediately repeats its saving throw with advantage. Until the end of your next turn, targets gain a +1 bonus to attack rolls and Wisdom saves.</p><p><strong>Higher Spend (upcast):</strong></p><ul><li><strong>+2 Spirituality:</strong> Target up to 4 allies and grant temporary HP equal to your Potency.</li><li><strong>+4 Spirituality:</strong> Duration becomes 1 minute (concentration); affected allies gain advantage on fear saves while they can hear your song.</li><li><strong>+6 Spirituality:</strong> Once during duration, each affected ally can add your Potency to one failed save against fear or charm, potentially turning it into a success.</li></ul><p><em>Counterplay:</em> The sustained effect ends if you are silenced, unable to vocalize, or voluntarily stop performing.</p>",
      "chat": ""
    },
